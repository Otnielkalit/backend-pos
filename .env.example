# Application
APP_PORT=8080
APP_ENV=development
APP_NAME=pos-backend

# Database (PostgreSQL)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DB_URL=postgres://posuser:pospassword@localhost:5432/pos_db?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=5

# Redis
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TOKEN_TTL_HOURS=24

# OAuth2 (optional, needed only when auth feature is implemented)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
