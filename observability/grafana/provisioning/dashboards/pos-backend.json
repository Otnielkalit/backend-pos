{
  "title": "POS Backend Dashboard",
  "uid": "pos-backend-01",
  "refresh": "10s",
  "panels": [
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_requests_total)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "In-Flight Requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "http_requests_in_flight",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate (per sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by(route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{job=\"pos-backend\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true
      }
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser"
}
